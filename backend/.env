# Môi trường Backend mOC-iSVM
# ==================================================
# QUAN TRỌNG: Thay đổi JWT_SECRET trước khi deploy production!

# JWT Configuration
JWT_SECRET=mocsvm-super-secret-jwt-key-change-in-production-2025
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# Database
DATABASE_URL=sqlite:///./mocsvm.db

# CORS Origins (phân cách bởi dấu phẩy)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:80

# Đường dẫn thư mục
MODEL_DIR=models
MANIFEST_PATH=models/global_manifest.xml
UPLOAD_DIR=data/uploads
